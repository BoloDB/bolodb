# ── Required ──
# Generate a secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
# PostgreSQL connection string (Supabase or self-hosted)
DATABASE_URL=
# Supabase project credentials (used for auth token verification)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# ── AI ──
# OpenRouter API key (https://openrouter.ai/keys)
# Used to generate SQL from natural-language questions via DeepSeek V4 Flash.
OPENROUTER_API_KEY=

# ── Email (optional) ──
# Email verification at signup (https://client.myemailverifier.com/)
MYEMAILVERIFIER_API_KEY=
# Transactional emails — verification links, password resets (https://resend.com/api-keys)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@bolodb.dev
# Frontend URL for building email reset/verification links
FRONTEND_URL=

# ── Analytics (optional) ──
# PostHog anonymous product analytics (respects Do Not Track)
PUBLIC_POSTHOG_PROJECT_TOKEN=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Connection encryption (required for storing DB URLs at rest) ──
# One of these MUST be set, or saved connections cannot be stored or reopened.
# Keep them independent from JWT_SECRET — rotating auth must not brick credentials.
# Generate with: openssl rand -base64 32
RECENT_CONNECTIONS_MASTER_KEY=     # Master key for key rotation (encrypts the key file)
# RECENT_CONNECTIONS_KEY=          # Direct encryption key (alternative to master key)
#
# Upgrading an instance that ran before this was required? Its key file was
# written with JWT_SECRET as the master key — set RECENT_CONNECTIONS_MASTER_KEY
# to that same JWT_SECRET value once, or existing saved connections stay
# unreadable and have to be re-added.

# ── Server (advanced) ──
# Set to "true" when behind HTTPS termination (nginx with SSL)
COOKIE_SECURE=false
# Skip Alembic advisory lock on startup (useful for multiple replicas)
SKIP_DB_LOCK=false
# Comma-separated allowed CORS origins (default: http://localhost:5173,http://localhost)
# CORS_ORIGINS=
# Set automatically in Docker; controls SQLite path selection
# RUNNING_IN_DOCKER=true
